# Copy this file to .env and replace the example values
# with your real credentials.
# Never commit the .env file to Git.

# Telegram bot token received from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:AAExampleFakeTelegramBotToken

# CoinGecko Demo API key received from the Developer Dashboard.
COINGECKO_API_KEY=CG-ExampleFakeCoinGeckoDemoApiKey

# Maximum successful crypto conversions allowed per user each UTC day.
CRYPTO_CONVERSIONS_PER_USER_PER_DAY=10

# Maximum CoinGecko HTTP requests allowed for the bot each UTC day.
COINGECKO_REQUESTS_PER_DAY=250

# Maximum crypto amount and ticker pairs processed from one message.
MAX_CRYPTO_PAIRS_PER_MESSAGE=5

# Telegram group ID that receives a shared priority conversion limit.
# Replace your_group_id with the numeric chat ID. Group IDs are usually negative.
PRIORITY_GROUP_ID=your_group_id

# Telegram user ID that receives a personal priority conversion limit.
# Replace your_user_id with the numeric user ID.
PRIORITY_USER_ID=your_user_id

# Maximum daily conversions shared by the configured priority group.
PRIORITY_GROUP_CONVERT_LIMIT=100

# Maximum daily conversions for the configured priority user.
PRIORITY_USER_CONVERT_LIMIT=25
