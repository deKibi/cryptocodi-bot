# Copy this file to .env and replace the example values
# with your real credentials.
# Never commit the .env file to Git.

# Telegram bot token received from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:AAExampleFakeTelegramBotToken

# CoinGecko Demo API key received from the Developer Dashboard.
COINGECKO_API_KEY=CG-ExampleFakeCoinGeckoDemoApiKey

# Daily conversion quota per user. Known tickers cost 1, unknown tickers cost 0.5.
CRYPTO_CONVERSIONS_PER_USER_PER_DAY=10

# Maximum CoinGecko HTTP requests allowed for the bot each UTC day.
COINGECKO_REQUESTS_PER_DAY=250

# Maximum crypto amount and ticker pairs processed from one message.
MAX_CRYPTO_PAIRS_PER_MESSAGE=5

# Telegram group IDs that receive a shared priority conversion limit.
# Separate multiple numeric chat IDs with commas. Group IDs are usually negative.
# A single numeric chat ID is also supported.
PRIORITY_GROUPS_ID=-1001234567890,-1009876543210
# Daily conversion quota shared by the configured priority group.
PRIORITY_GROUP_CONVERT_LIMIT=100

# Telegram user IDs that receive a personal priority conversion limit.
# Separate multiple numeric user IDs with commas.
# A single numeric user ID is also supported.
PRIORITY_USERS_ID=123456789,987654321
# Daily conversion quota for the configured priority user.
PRIORITY_USER_CONVERT_LIMIT=25
